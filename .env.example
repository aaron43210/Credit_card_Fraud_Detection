# IEEE Fraud Detection Dataset
# Set this to the folder containing:
# - train_transaction.csv
# - train_identity.csv
# - test_transaction.csv
# - test_identity.csv
# Download from: https://www.kaggle.com/c/ieee-fraud-detection/data
IEEE_FRAUD_DATA_DIR=./data

# Optional: Native library threading (for stability on macOS/Linux)
OMP_NUM_THREADS=1
MKL_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
